# Set default behavior to handle line endings.
* text=auto

# Force LF for shell scripts and other common text files.
*.sh text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.astro text eol=lf
*.css text eol=lf
*.md text eol=lf

# Keep binary files as-is.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.mov binary
*.mp4 binary
