---
import site from '../content/settings/site.json';
import { withBase } from '../lib/assets';
---

<footer class="site-footer">
  <div class="container site-footer-grid">
    <div>
      <a class="footer-brandmark" href="https://portale.unipv.it/it" aria-label="University of Pavia">
        <img src={withBase('/images/brand/unipv-logo-new.svg')} alt="University of Pavia" />
      </a>
    </div>
    <div class="footer-department">
      <div class="site-footer-title">Department</div>
      <div>Department of Industrial and Information Engineering</div>
    </div>
    <div class="footer-meta">
      <a class="footer-brandmark footer-ramslab" href="https://rams.unipv.it/" aria-label="RAMSLAB">
        <img src={withBase('/images/brand/ramslab-footer-logo.svg')} alt="RAMSLAB" />
      </a>
    </div>
  </div>
</footer>
