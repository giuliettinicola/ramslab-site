---
import site from '../content/settings/site.json';
import { withBase } from '../lib/assets';
---

<footer class="site-footer">
  <div class="container site-footer-grid">
    <div>
      <a class="footer-brandmark" href="https://rams.unipv.it/" aria-label="University of Pavia">
        <img src={withBase('/images/brand/unipv-main-logo-white.png')} alt="University of Pavia" />
      </a>
    </div>
    <div class="footer-department">
      <div class="site-footer-title">Department</div>
      <div>Department of Industrial and Information Engineering</div>
    </div>
    <div class="footer-meta">
      <a class="footer-brandmark footer-ramslab" href="https://rams.unipv.it/" aria-label="RAMSLAB">
        <img src={withBase('/images/brand/ramslab-logo-white.svg')} alt="RAMSLAB" />
      </a>
      {site.contactEmail && <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>}
    </div>
  </div>
</footer>
