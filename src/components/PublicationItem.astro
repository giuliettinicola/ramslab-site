---
import ArchiveItem from './ArchiveItem.astro';

interface Props {
  title: string;
  authors: string[];
  year: number;
  venue?: string;
  url?: string;
  doi?: string;
}

const { title, authors, year, venue, url, doi } = Astro.props;
const otherInfo = [venue, doi ? `DOI: ${doi}` : ''].filter(Boolean).join('. ');
---

<article class="pub-item">
  <div class="pub-title">{title}</div>
  <div class="pub-authors">{authors.join(', ')} ({year}).</div>
  {otherInfo && <div class="pub-venue">{otherInfo}.</div>}
  {(doi || url) && <a href={doi ? `https://doi.org/${doi}` : url} class="pub-link" target={doi ? "_blank" : undefined} rel={doi ? "noopener noreferrer" : undefined}>[link]</a>}
</article>
