---
import '../styles/global.css';
import site from '../content/settings/site.json';

interface Props {
  title?: string;
  description?: string;
}

const { title = site.siteTitle, description = site.siteDescription } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Auth guard: runs before paint to avoid flash -->
    <script is:inline>
      (function () {
        var role = sessionStorage.getItem('ramslab_role');
        var path = window.location.pathname.replace(/\/+$/, '');
        var loginPath = '/ramslab-site/login';

        // Already on login page — skip
        if (path === loginPath) return;

        // Not authenticated → go to login
        if (role !== 'user' && role !== 'admin') {
          window.location.replace('/ramslab-site/login/');
          return;
        }

        // role=user on a project detail page → show Under Construction
        var projectsBase = '/ramslab-site/projects';
        var isProjectDetail =
          path.startsWith(projectsBase) &&
          path !== projectsBase &&
          path !== projectsBase + '/index';

        if (role === 'user' && isProjectDetail) {
          document.addEventListener('DOMContentLoaded', function () {
            var overlay = document.createElement('div');
            overlay.id = 'under-construction-overlay';
            overlay.style.cssText = [
              'position:fixed', 'inset:0', 'z-index:9999',
              'background:#ffffff',
              'display:flex', 'flex-direction:column',
              'align-items:center', 'justify-content:center', 'gap:32px',
              'font-family:"Helvetica Neue",Helvetica,Arial,sans-serif'
            ].join(';');

            var logo = document.createElement('img');
            logo.src = '/ramslab-site/images/brand/ramslab-logo-header.svg';
            logo.alt = 'RAMSLAB';
            logo.style.cssText = 'height:24px;width:auto;opacity:0.35;';

            var text = document.createElement('div');
            text.style.cssText = [
              'text-align:center', 'display:flex', 'flex-direction:column', 'gap:12px'
            ].join(';');

            var heading = document.createElement('p');
            heading.textContent = 'Under Construction';
            heading.style.cssText = [
              'margin:0', 'font-size:11px', 'font-weight:700',
              'letter-spacing:0.12em', 'text-transform:uppercase', 'color:#111'
            ].join(';');

            var sub = document.createElement('p');
            sub.textContent = 'This page is not yet available.';
            sub.style.cssText = 'margin:0;font-size:13px;color:#5f5f5f;';

            var back = document.createElement('a');
            back.href = '/ramslab-site/';
            back.textContent = '← Back to home';
            back.style.cssText = [
              'margin-top:8px', 'font-size:11px', 'font-weight:700',
              'letter-spacing:0.08em', 'text-transform:uppercase',
              'color:#111', 'text-decoration:underline',
              'text-underline-offset:0.3em'
            ].join(';');

            text.appendChild(heading);
            text.appendChild(sub);
            text.appendChild(back);
            overlay.appendChild(logo);
            overlay.appendChild(text);
            document.body.appendChild(overlay);
          });
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
  </body>
</html>
