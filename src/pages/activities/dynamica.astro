---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/assets';

const project = {
  title: "DYNAMICA",
  subtitle: "Collaborative Robotics & Mixed Reality",
  vision: "Seamlessly merging human intuition with artificial intelligence in mixed reality.",
  description: "DYNAMICA represents a paradigm shift in human-robot collaboration. By combining advanced AI agents with immersive mixed reality interfaces, the project enables operators to interact with robotic systems through natural gestures and intuitive commands. This research bridges the gap between complex industrial automation and human-centric operation, featuring real-time intent prediction algorithms, virtual training simulators, and seamless physical-digital integration. DYNAMICA redefines how we teach, control, and collaborate with autonomous systems in dynamic environments.",
  publications: [
    { title: "Predictive AI Agents for Human-Robot Collaboration in Dynamic Environments", url: "#" },
    { title: "Mixed Reality Interfaces for Intuitive Robotic Arm Programming", url: "#" },
    { title: "Towards Seamless Integration of Digital Twins and Physical Manipulation", url: "#" }
  ],
  funding: "Produced within the PRIN project framework, focused on dynamic interactions and control in multi-agent robotic systems."
};
---

<BaseLayout title={`${project.title} — Immersive Experience`}>
  <div class="scrolly-container">
    <!-- FIXED LOGO OVERLAY -->
    <div class="fixed-ui">
      <div class="brand-logos">
        <a href="https://portale.unipv.it/it" target="_blank" rel="noopener noreferrer">
          <img src={withBase('/images/brand/unipv-main-logo-white.png')} alt="UNIPV" class="logo-unipv" />
        </a>
        <div class="logo-separator"></div>
        <a href={withBase('/')}>
          <img src={withBase('/images/brand/ramslab-logo-white.svg')} alt="RAMS Lab" class="logo-ramslab" />
        </a>
      </div>
      <a href={withBase('/activities/')} class="back-btn">← Back to Activities</a>
    </div>

    <!-- SECTION 1: HERO -->
    <section class="section hero-section">
      <div class="bg-media">
        <img src={withBase('/images/projects/Dynamica.png')} alt="Dynamica Hero Background" class="hero-bg-image" />
        <div class="bg-overlay"></div>
      </div>
      <div class="content">
        <h1 class="title-main">{project.title}</h1>
        <p class="subtitle">{project.subtitle}</p>
      </div>
    </section>

    <!-- SECTION 2: VISION -->
    <section class="section vision-section carbon-bg">
      <div class="bg-media">
        <img src={withBase('/images/projects/carbon-fiber-bg.png')} alt="Carbon Fiber" class="parallax-bg" />
        <div class="digital-mesh-overlay"></div>
      </div>
      <div class="content vision-content reveal">
        <h2 class="vision-phrase">{project.vision}</h2>
      </div>
    </section>

    <!-- SECTION 3: INTUITIVE PROGRAMMING -->
    <section class="section content-section">
      <div class="bg-media abstract-bg"></div>
      <div class="content-grid container">
        <div class="text-block reveal">
          <h2 class="section-label">Intuitive Programming</h2>
          <p>Break down the barriers of traditional coding. Operators can now manage robotic actions through natural hand gestures and AI-assisted interpretation, translating human intent directly into machine execution.</p>
        </div>
        <div class="visual-block reveal">
          <div class="tech-image-container">
            <img src={withBase('/images/projects/dynamica_programming.png')} alt="Intuitive Programming" class="tech-image" />
            <div class="glow-border"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 4: MIXED REALITY TRAINING -->
    <section class="section content-section alternate">
      <div class="bg-media abstract-bg-2"></div>
      <div class="content-grid container">
        <div class="visual-block reveal">
          <div class="tech-image-container">
            <img src={withBase('/images/projects/dynamica_training.png')} alt="Mixed Reality Training" class="tech-image" />
            <div class="glow-border"></div>
          </div>
        </div>
        <div class="text-block reveal">
          <h2 class="section-label">Mixed Reality Training</h2>
          <p>Safely master complex robotic operations within highly immersive virtual simulators. The boundaries between physical hardware and digital environments dissolve, providing a realistic, risk-free training arena.</p>
        </div>
      </div>
    </section>

    <!-- SECTION 5: AI AGENTS -->
    <section class="section content-section">
      <div class="bg-media abstract-bg"></div>
      <div class="content-grid container">
        <div class="text-block reveal">
          <h2 class="section-label">AI Agents</h2>
          <p>Equipped with advanced machine learning algorithms, the system actively anticipates operator movements. By predicting human intentions in real-time, the robotic system seamlessly adapts, ensuring perfectly synchronized collaboration.</p>
        </div>
        <div class="visual-block reveal">
          <div class="tech-image-container">
            <img src={withBase('/images/projects/dynamica_ai.png')} alt="AI Agents" class="tech-image" />
            <div class="glow-border"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 6: RECAP -->
    <section class="recap-section">
      <div class="container">
        <div class="info-box">
          <div class="info-grid">
            <div class="info-column main-info">
              <h2 class="info-label">Description</h2>
              <p class="info-description">{project.description}</p>
            </div>
            
            <div class="info-column side-info">
              <div class="info-group">
                <h3 class="info-label">Publications</h3>
                <ul class="info-list">
                  {project.publications.map(pub => (
                    <li><a href={pub.url}>{pub.title}</a></li>
                  ))}
                </ul>
              </div>

              <div class="info-group">
                <h3 class="info-label">Team</h3>
                <ul class="info-list team-list">
                  <li><strong>Dr. Jane Doe</strong> - Lead Researcher</li>
                  <li><strong>John Smith</strong> - Robotics Engineer</li>
                  <li><strong>Alan Turing</strong> - AI Specialist</li>
                  <li><strong>Ada Lovelace</strong> - MR Developer</li>
                </ul>
              </div>

              <div class="info-group mt-4">
                <h3 class="info-label">Funding</h3>
                <p class="funding-text">{project.funding}</p>
              </div>
            </div>
          </div>
          <footer class="info-footer">
            <a href={withBase('/activities/')} class="back-link">← Return to Activities</a>
          </footer>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Michroma&family=Space+Grotesk:wght@300;400;600&display=swap');

  :root {
    --color-cyan: #22d3ee;
    --color-indigo: #6366f1;
    --color-bg-dark: #020617;
    --color-bg-carbon: #050505;
    --font-title: 'Michroma', sans-serif;
    --font-text: 'Space Grotesk', monospace, sans-serif;
  }

  .scrolly-container {
    background-color: var(--color-bg-dark);
    color: white;
    font-family: var(--font-text);
    scroll-snap-type: y proximity; /* using proximity to allow recap to scroll normally if needed */
  }

  /* FIXED UI */
  .fixed-ui {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background-color: var(--color-bg-dark);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1.25rem 2rem;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .brand-logos {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    opacity: 0.9;
  }

  .logo-unipv { height: 36px; filter: brightness(0) invert(1); }
  .logo-ramslab { height: 28px; filter: brightness(0) invert(1); }
  .logo-separator { width: 1px; height: 24px; background-color: rgba(255, 255, 255, 0.3); }

  .back-btn {
    color: #ffffff;
    text-decoration: none;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 0.5rem 1rem;
    transition: all 0.3s ease;
    font-weight: 600;
    background: transparent;
  }

  .back-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    border-color: #ffffff;
  }

  @media (max-width: 768px) {
    .fixed-ui {
      padding: 0.75rem 1rem;
    }
    .brand-logos {
      gap: 1rem;
    }
    .logo-unipv {
      height: 28px;
    }
    .logo-ramslab {
      height: 22px;
    }
    .logo-separator {
      height: 18px;
    }
    .back-btn {
      padding: 0.35rem 0.7rem;
      font-size: 0.65rem;
      letter-spacing: 0.10em;
    }
  }

  /* SECTION BASE */
  .section {
    position: relative;
    height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    scroll-snap-align: start;
  }

  .bg-media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .bg-media img { width: 100%; height: 100%; object-fit: cover; opacity: 0.5; }

  .bg-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent, rgba(2,6,23,0.9));
  }

  .content { position: relative; z-index: 2; text-align: center; max-width: 900px; padding: 2rem; }

  /* HERO */
  .title-main { 
    font-family: var(--font-title);
    font-size: clamp(4rem, 12vw, 8rem); 
    font-weight: 400; 
    margin: 0; 
    line-height: 1; 
    color: #ffffff;
    text-shadow: 0 0 20px rgba(34, 211, 238, 0.6), 0 0 40px rgba(99, 102, 241, 0.4);
    letter-spacing: 0.05em;
  }
  .subtitle { 
    font-size: 1.25rem; 
    letter-spacing: 0.2em; 
    text-transform: uppercase; 
    margin-top: 1.5rem; 
    color: var(--color-cyan);
    opacity: 0.9; 
    font-weight: 300;
  }

  /* VISION SECTION */
  .carbon-bg { background-color: var(--color-bg-carbon); }
  .digital-mesh-overlay {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(34, 211, 238, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(34, 211, 238, 0.05) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.5;
  }
  .vision-phrase {
    font-family: var(--font-text);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.3;
    font-weight: 300;
    color: #ffffff;
    letter-spacing: 0.02em;
    text-shadow: 0 0 10px rgba(34, 211, 238, 0.2);
  }

  /* CONTENT SECTIONS */
  .abstract-bg { background: radial-gradient(circle at 100% 50%, rgba(99, 102, 241, 0.1), var(--color-bg-dark) 60%); }
  .abstract-bg-2 { background: radial-gradient(circle at 0% 50%, rgba(34, 211, 238, 0.1), var(--color-bg-dark) 60%); }
  
  .content-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; width: 100%; padding: 0 4rem; max-width: 1400px; margin: 0 auto; position: relative; z-index: 2;}
  .visual-block { display: flex; justify-content: center; align-items: center; width: 100%; }
  .alternate .content-grid { grid-template-columns: 1fr 1fr; }
  
  .section-label { 
    font-family: var(--font-title);
    color: var(--color-cyan); 
    text-transform: uppercase; 
    font-size: 1.25rem; 
    margin-bottom: 1.5rem; 
    letter-spacing: 0.1em;
  }
  .text-block p { 
    font-size: 1.25rem; 
    line-height: 1.6; 
    opacity: 0.8; 
    font-weight: 300;
  }

  /* TECH IMAGES */
  .tech-image-container {
    position: relative;
    width: 100%;
    max-width: 500px;
    aspect-ratio: 4/3;
  }
  .tech-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 4px;
    filter: brightness(0.9) contrast(1.1);
  }
  .glow-border {
    position: absolute;
    inset: -2px;
    border: 1px solid rgba(34, 211, 238, 0.4);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.2);
    border-radius: 4px;
    pointer-events: none;
    z-index: 3;
  }
  
  .glow-border::before, .glow-border::after {
    content: '';
    position: absolute;
    width: 20px;
    height: 20px;
    border: 2px solid var(--color-cyan);
  }
  .glow-border::before { top: -2px; left: -2px; border-right: none; border-bottom: none; }
  .glow-border::after { bottom: -2px; right: -2px; border-left: none; border-top: none; }

  /* RECAP SECTION */
  .recap-section { padding: 120px 0; background-color: white; color: black; scroll-snap-align: start; font-family: system-ui, -apple-system, sans-serif;}
  .info-box { background-color: #f8fafc; border-radius: 4px; padding: 60px; max-width: 1100px; margin: 0 auto; border: 1px solid #e2e8f0; }
  .info-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 80px; }
  .info-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 24px; color: #64748b; font-weight: 700; }
  .info-description { font-size: 1.5rem; line-height: 1.4; font-weight: 400; color: #0f172a; }
  .info-group { margin-bottom: 40px; }
  .info-list { list-style: none; padding: 0; margin: 0; }
  .info-list li { padding: 12px 0; border-top: 1px solid rgba(0, 0, 0, 0.05); font-size: 1rem; color: #334155; }
  .info-list a { color: #020617; text-decoration: none; transition: color 0.2s; }
  .info-list a:hover { color: #22d3ee; }
  .team-list li { padding: 8px 0; }
  .funding-text { font-size: 0.9rem; line-height: 1.5; color: #475569; }
  .info-footer { margin-top: 60px; padding-top: 32px; border-top: 1px solid rgba(0, 0, 0, 0.08); }
  .back-link { color: #64748b; text-decoration: none; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; }
  .mt-4 { margin-top: 2rem; }

  /* ANIMATIONS */
  .parallax-bg { transition: transform 0.1s ease-out; }
  .reveal { opacity: 0; transform: translateY(40px); transition: all 1s cubic-bezier(0.16, 1, 0.3, 1); }
  .reveal.active { opacity: 1; transform: translateY(0); }

  @media (max-width: 768px) {
    .content-grid { grid-template-columns: 1fr; padding: 0 2rem; gap: 2rem; }
    .alternate .content-grid { display: flex; flex-direction: column-reverse; }
    .title-main { font-size: clamp(3rem, 10vw, 5rem); }
    .vision-phrase { font-size: 1.75rem; }
    .info-grid { grid-template-columns: 1fr; gap: 40px; }
    .info-box { padding: 30px; }
  }
</style>

<script>
  function initReveal() {
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
    
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      document.querySelectorAll('.parallax-bg').forEach(bg => {
        const speed = 0.25;
        (bg as HTMLElement).style.transform = `translateY(${scrollY * speed}px)`;
      });
    });
  }

  // Execution
  initReveal();
</script>
