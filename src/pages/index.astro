---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/assets';
import { entrySlug } from '../lib/entries';
import { formatDate } from '../lib/format';
import site from '../content/settings/site.json';

const projects = (await getCollection('projects')).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return Number(b.data.featured) - Number(a.data.featured);
  return (b.data.year ?? 0) - (a.data.year ?? 0);
});
const featuredProjects = projects.slice(0, 12);
const allPeople = (await getCollection('people')).sort((a, b) => a.data.order - b.data.order);
const people = allPeople.slice(0, 5);
const otherPeople = allPeople.slice(5).sort((a, b) => {
  const surnameA = a.data.name.split(' ').pop() || '';
  const surnameB = b.data.name.split(' ').pop() || '';
  return surnameA.localeCompare(surnameB);
});
const publications = (await getCollection('publications')).sort((a, b) => b.data.year - a.data.year).slice(0, 4);

const introColumns = [
  'Welcome to RAMS lab! Our aim is to bring innovation and creativity to industrial and research applications using cutting-edge robotics and dynamic simulators. Our team of researchers is dedicated to advancing the field of robotics and simulators in order to revolutionize the way industries operate. We are constantly exploring new ways to apply this technology to enhance productivity, improve safety, and reduce costs.',
  'One of our main focuses is on developing simulators for sports and driving. Our state-of-the-art simulators are designed to provide athletes and drivers with a realistic training experience, allowing them to improve their skills and performance in a safe and controlled environment. These simulators are also a valuable tool for medical researches, as they can be used to analyze and optimize performances of people who need rehabilitation in a controlled environment.',
  'In addition to our work in simulators, we also specialize in robotics for industrial applications. Our team is constantly developing new robotic applications that can be used in a wide range of industries, from manufacturing and logistics to healthcare and agriculture. Our goal is to make these systems more efficient, reliable, and cost-effective, so that they can be widely adopted and make a significant impact on the industries they serve.'
];
---

<BaseLayout title={site.siteTitle}>
  <Header />
  <main>
    <section class="home-intro">
      <div class="container home-intro-grid">
        <div class="home-intro-label">
          <div class="label">Laboratory</div>
          <div class="caption">{site.siteMotto ?? site.siteDescription}</div>
        </div>
        {introColumns.map((paragraph) => (
          <div class="home-intro-copy">
            <p>{paragraph}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="container">
      <SectionTitle title="Projects" note="Selected entries from the current placeholder archive. Scroll horizontally to browse the strip." />
      <div class="media-strip">
        {featuredProjects.map((project) => (
          <ProjectCard
            href={withBase(`/projects/${entrySlug(project.id)}/`)}
            title={project.data.title}
            meta={[project.data.year?.toString(), project.data.status].filter(Boolean).join(' · ')}
            src={project.data.cover}
          />
        ))}
      </div>
    </section>

    <section class="container home-columns">
      <div class="home-column">
        <h2 class="home-column-title">Publications</h2>
        <div class="dense-list">
          {publications.map((publication) => (
            <article class="dense-item">
              <div class="dense-title">{publication.data.title}</div>
              <div class="dense-meta">{publication.data.authors.join(', ')}</div>
              {publication.data.venue && <div class="dense-text"><em>{publication.data.venue}</em></div>}
            </article>
          ))}
          <div class="home-column-footer">
            <a href={withBase('/publications/')} class="browse-link">browse all publications</a>
          </div>
        </div>
      </div>

      <div class="home-column">
        <h2 class="home-column-title">People</h2>
        <div class="dense-list">
          {people.map((person) => (
            <article class="dense-item">
              <div class="dense-title"><a href={withBase(`/people/${entrySlug(person.id)}/`)}>{person.data.name}</a></div>
              <div class="dense-meta">{person.data.role}</div>
            </article>
          ))}
        </div>
        {otherPeople.length > 0 && (
          <div class="home-column-footer" style="margin-top: 8px;">
            {otherPeople.map((person, index) => {
              return (
                <Fragment>
                  <a href={withBase(`/people/${entrySlug(person.id)}/`)} style="font-size: 0.82rem; font-weight: 400; color: var(--text); text-decoration: none;">{person.data.name}</a>{index < otherPeople.length - 1 ? ', ' : ''}
                </Fragment>
              );
            })}
          </div>
        )}
      </div>

      <div class="home-column">
        <h2 class="home-column-title">About</h2>
        <div class="dense-list">
          <article class="dense-item">
            <div class="dense-title"><a href={withBase('/about/')}>Laboratory profile</a></div>
            <div class="dense-text">Overview, scope, contact information, and the current structure of the RAMSLAB site.</div>
          </article>
          <article class="dense-item">
            <div class="dense-title"><a href={withBase('/projects/')}>Project archive</a></div>
            <div class="dense-text">Research projects, prototypes, and collaborative investigations.</div>
          </article>
          <article class="dense-item">
            <div class="dense-title"><a href={withBase('/publications/')}>Publication archive</a></div>
            <div class="dense-text">Grouped research outputs indexed by year.</div>
          </article>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
