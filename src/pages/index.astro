---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/assets';
import { entrySlug } from '../lib/entries';
import { formatDate } from '../lib/format';
import site from '../content/settings/site.json';

const projects = (await getCollection('projects')).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return Number(b.data.featured) - Number(a.data.featured);
  return (b.data.year ?? 0) - (a.data.year ?? 0);
});
const featuredProjects = projects.slice(0, 12);
const people = (await getCollection('people')).sort((a, b) => a.data.order - b.data.order).slice(0, 5);
const publications = (await getCollection('publications')).sort((a, b) => b.data.year - a.data.year).slice(0, 4);
const news = (await getCollection('news')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 4);
const consortium = (await getCollection('consortium')).sort((a, b) => a.data.order - b.data.order).slice(0, 4);

const introColumns = [
  'RAMSLAB is a research laboratory at the University of Pavia focused on measurements, systems, computer vision, robotics, and digitally mediated observation.',
  'This rebuild is intentionally structured as an editorial archive. Projects, publications, people, and institutional information are presented through lists, detail pages, and reusable content entries rather than a promotional landing page.',
  'The current material remains placeholder content. The purpose of this phase is to validate information architecture, layout rhythm, and hierarchy before the final RAMSLAB archive is migrated.'
];
---

<BaseLayout title={site.siteTitle}>
  <Header />
  <main>
    <section class="home-intro">
      <div class="container home-intro-grid">
        <div class="home-intro-label">
          <div class="label">Laboratory</div>
          <div class="caption">{site.siteDescription}. Static Astro archive with structured content collections.</div>
        </div>
        {introColumns.map((paragraph) => (
          <div class="home-intro-copy">
            <p>{paragraph}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="container">
      <SectionTitle title="Projects" note="Selected entries from the current placeholder archive. Scroll horizontally to browse the strip." />
      <div class="media-strip">
        {featuredProjects.map((project) => (
          <ProjectCard
            href={withBase(`/projects/${entrySlug(project.id)}/`)}
            title={project.data.title}
            meta={[project.data.year?.toString(), project.data.status].filter(Boolean).join(' · ')}
            src={project.data.cover}
          />
        ))}
      </div>
    </section>

    <section class="container home-columns">
      <div class="home-column">
        <h2 class="home-column-title">Consortium</h2>
        <div class="dense-list">
          {consortium.map((partner) => (
            <article class="dense-item">
              <div class="dense-title">
                {partner.data.website ? <a href={partner.data.website}>{partner.data.name}</a> : partner.data.name}
              </div>
              {partner.data.description && <div class="dense-text">{partner.data.description}</div>}
            </article>
          ))}
        </div>
      </div>

      <div class="home-column">
        <h2 class="home-column-title">Publications</h2>
        <div class="dense-list">
          {publications.map((publication) => (
            <article class="dense-item">
              <div class="dense-meta">{publication.data.year}</div>
              <div class="dense-title">
                {publication.data.url ? <a href={publication.data.url}>{publication.data.title}</a> : publication.data.title}
              </div>
              <div class="dense-text">{publication.data.authors.join(', ')}</div>
            </article>
          ))}
        </div>
      </div>

      <div class="home-column">
        <h2 class="home-column-title">News</h2>
        <div class="dense-list">
          {news.map((item) => (
            <article class="dense-item">
              <div class="dense-meta">{formatDate(item.data.date)}</div>
              <div class="dense-title"><a href={withBase(`/news/${entrySlug(item.id)}/`)}>{item.data.title}</a></div>
              <div class="dense-text">{item.data.excerpt}</div>
            </article>
          ))}
        </div>
      </div>

      <div class="home-column">
        <h2 class="home-column-title">People</h2>
        <div class="dense-list">
          {people.map((person) => (
            <article class="dense-item">
              <div class="dense-title"><a href={withBase(`/people/${entrySlug(person.id)}/`)}>{person.data.name}</a></div>
              <div class="dense-meta">{person.data.role}</div>
              {person.data.shortBio && <div class="dense-text">{person.data.shortBio}</div>}
            </article>
          ))}
        </div>
      </div>

      <div class="home-column">
        <h2 class="home-column-title">About</h2>
        <div class="dense-list">
          <article class="dense-item">
            <div class="dense-title"><a href={withBase('/about/')}>Laboratory profile</a></div>
            <div class="dense-text">Overview, scope, contact information, and the current structure of the RAMSLAB site.</div>
          </article>
          <article class="dense-item">
            <div class="dense-title"><a href={withBase('/projects/')}>Project archive</a></div>
            <div class="dense-text">Research projects, prototypes, and collaborative investigations.</div>
          </article>
          <article class="dense-item">
            <div class="dense-title"><a href={withBase('/publications/')}>Publication archive</a></div>
            <div class="dense-text">Grouped research outputs indexed by year.</div>
          </article>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
