---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection, render } from 'astro:content';
import { withBase } from '../../lib/assets';
import { entrySlug } from '../../lib/entries';
import { formatDate } from '../../lib/format';

export async function getStaticPaths() {
  const news = await getCollection('news');
  return news.map((item) => ({ params: { slug: entrySlug(item.id) }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const projects = await getCollection('projects');
const relatedProjects = projects.filter((project) => item.data.relatedProjects.includes(entrySlug(project.id)));
---

<BaseLayout title={`${item.data.title} — RAMSLAB`}>
  <Header />
  <main>
    <PageHeader
      section="News"
      title={item.data.title}
      description={item.data.excerpt}
      note={formatDate(item.data.date)}
    />
    <section class="detail-section">
      <div class="container detail-layout">
        <aside class="detail-aside">
          <div class="detail-block">
            <div class="detail-block-label">Date</div>
            <div>{formatDate(item.data.date)}</div>
          </div>

          {relatedProjects.length > 0 && (
            <div class="detail-block">
              <div class="detail-block-label">Related projects</div>
              {relatedProjects.map((project) => <a href={withBase(`/projects/${entrySlug(project.id)}/`)}>{project.data.title}</a>)}
            </div>
          )}
        </aside>

        <article class="detail-main">
          {item.data.cover && (
            <figure class="detail-media">
              <img src={withBase(item.data.cover)} alt={item.data.title} />
            </figure>
          )}
          <div class="detail-content">
            <Content />
          </div>
        </article>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
