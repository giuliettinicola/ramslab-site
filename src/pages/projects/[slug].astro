---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection, render } from 'astro:content';
import { withBase } from '../../lib/assets';
import { entrySlug } from '../../lib/entries';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: entrySlug(project.id) }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const people = await getCollection('people');
const publications = await getCollection('publications');
const consortium = await getCollection('consortium');
const relatedPeople = people.filter((person) => project.data.people.includes(entrySlug(person.id)));
const relatedPublications = publications.filter((publication) => project.data.publications.includes(entrySlug(publication.id)));
const relatedPartners = consortium.filter((partner) => project.data.consortium.includes(entrySlug(partner.id)));
const note = [project.data.year ? String(project.data.year) : '', project.data.status].filter(Boolean).join(' · ');
---

<BaseLayout title={`${project.data.title} — RAMSLAB`}>
  <Header />
  <main>
    <PageHeader
      section="Projects"
      title={project.data.title}
      description={project.data.excerpt}
      note={note}
    />
    <section class="detail-section">
      <div class="container detail-layout">
        <aside class="detail-aside">
          <div class="detail-block">
            <div class="detail-block-label">Record</div>
            {project.data.year && <div>{project.data.year}</div>}
            {project.data.status && <div>{project.data.status}</div>}
          </div>

          {project.data.tags.length > 0 && (
            <div class="detail-block">
              <div class="detail-block-label">Tags</div>
              {project.data.tags.map((tag) => <div>{tag}</div>)}
            </div>
          )}

          {relatedPeople.length > 0 && (
            <div class="detail-block">
              <div class="detail-block-label">People</div>
              {relatedPeople.map((person) => <a href={`/people/${entrySlug(person.id)}/`}>{person.data.name}</a>)}
            </div>
          )}

          {relatedPublications.length > 0 && (
            <div class="detail-block">
              <div class="detail-block-label">Publications</div>
              {relatedPublications.map((publication) => (
                publication.data.url ? <a href={publication.data.url}>{publication.data.title}</a> : <div>{publication.data.title}</div>
              ))}
            </div>
          )}

          {relatedPartners.length > 0 && (
            <div class="detail-block">
              <div class="detail-block-label">Consortium</div>
              {relatedPartners.map((partner) => (
                partner.data.website ? <a href={partner.data.website}>{partner.data.name}</a> : <div>{partner.data.name}</div>
              ))}
            </div>
          )}
        </aside>

        <article class="detail-main">
          {project.data.cover && (
            <figure class="detail-media">
              <img src={withBase(project.data.cover)} alt={project.data.title} />
            </figure>
          )}
          <div class="detail-content">
            <Content />
          </div>
        </article>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
