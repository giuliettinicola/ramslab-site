---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/assets';

const project = {
  title: "DEMETRA",
  subtitle: "Pruning Virtual Training Simulator",
  vision: "Redefining agricultural precision through immersive virtual environments and robotic simulation.",
  description: "DEMETRA is an advanced research platform focused on the digitization of pruning techniques. By combining high-fidelity physics simulations with immersive virtual reality, the project provides a safe and optimized environment for training agricultural workers and testing robotic pruning algorithms.",
  publications: [
    { title: "Virtual Reality for Agricultural Training: The DEMETRA Platform", url: "#" },
    { title: "Real-time Simulation of Pruning Dynamics in Virtual Environments", url: "#" },
    { title: "Robotic Pruning: A Survey of Simulation-to-Real Transfer", url: "#" }
  ],
  team: [
    { name: "Marco Carnevale", role: "Principal Investigator" },
    { name: "RAMS Lab Team", role: "Researchers & Developers" },
    { name: "University of Pavia", role: "Institutional Partner" }
  ],
  consortium: [
    "University of Pavia",
    "RAMS Lab",
    "DIII — Department of Industrial and Information Engineering"
  ]
};
---

<BaseLayout title={`${project.title} — Immersive Experience`}>
  <div class="scrolly-container">
    <!-- FIXED LOGO OVERLAY -->
    <div class="fixed-ui">
      <div class="brand-logos">
        <a href="https://portale.unipv.it/it" target="_blank" rel="noopener noreferrer">
          <img src={withBase('/images/brand/unipv-main-logo-white.png')} alt="UNIPV" class="logo-unipv" />
        </a>
        <div class="logo-separator"></div>
        <a href={withBase('/')}>
          <img src={withBase('/images/brand/ramslab-logo-white.svg')} alt="RAMS Lab" class="logo-ramslab" />
        </a>
      </div>
    </div>

    <!-- SECTION 1: HERO -->
    <section class="section hero-section">
      <div class="bg-media">
        <video 
          src={withBase('/videos/projects/0505(1).mp4')} 
          autoplay 
          loop 
          muted 
          playsinline 
          class="hero-bg-video"
        ></video>
        <div class="bg-overlay"></div>
      </div>
      <div class="content">
        <h1 class="title-main">{project.title}</h1>
        <p class="subtitle">{project.subtitle}</p>
      </div>
    </section>

    <!-- SECTION 2: VISION (Scrollytelling - In-place transitions) -->
    <!-- SECTION 2: UNLIMITED LOCOMOTION -->
    <section class="section content-section locomotion-bg">
      <div class="bg-media">
        <video 
          src={withBase('/videos/projects/0505(3).mp4')} 
          autoplay 
          loop 
          muted 
          playsinline 
          class="hero-bg-video"
        ></video>
        <div class="bg-overlay"></div>
      </div>
      <div class="content-grid container">
        <div class="text-block reveal">
          <h2 class="section-label">Unlimited Locomotion</h2>
          <p>Step into the Infinite. With our integrated omnidirectional treadmill, the digital twin becomes a boundless environment. Navigate through miles of virtual rows with the freedom of physical walking, bridging the gap between simulator and reality.</p>
        </div>
        <div class="visual-block reveal">
          <div class="tech-video-container side-sync-video">
            <video 
              src={withBase('/videos/projects/0505(4).mp4')} 
              autoplay 
              loop 
              muted 
              playsinline 
              class="tech-video"
            ></video>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 3: MODULAR CONTENT - THE SYSTEM -->
    <section class="section content-section nature-bg">
      <div class="bg-media">
        <img src={withBase('/images/projects/demetra-nature-texture.png')} alt="Nature Texture" class="parallax-bg" />
      </div>
      <div class="content-grid container">
        <div class="text-block reveal">
          <h2 class="section-label">Digital Twin</h2>
          <p>The system creates a perfect digital replica of agricultural environments, allowing for the precise modeling of tree morphology and pruning responses.</p>
        </div>
        <div class="visual-block reveal">
          <div id="tree-canvas-container" class="tree-3d-container" data-model={withBase('/models/tree.glb')}></div>
        </div>
      </div>
    </section>

    <!-- SECTION 4: MODULAR CONTENT - TRAINING -->
    <section class="section content-section alternate">
      <div class="content-grid container">
        <div class="visual-block reveal">
          <div class="abstract-viz">
            <div class="viz-line"></div>
            <div class="viz-line delay-1"></div>
            <div class="viz-line delay-2"></div>
          </div>
        </div>
        <div class="text-block reveal">
          <h2 class="section-label">Skill Acquisition</h2>
          <p>Real-time haptic feedback and visual analytics guide the user through complex pruning decisions, accelerating the learning curve for sustainable practices.</p>
        </div>
      </div>
    </section>

    <!-- SECTION 5: RECAP (Redesigned as Information Box) -->
    <section class="recap-section">
      <div class="container">
        <div class="info-box">
          <div class="info-grid">
            <div class="info-column main-info">
              <h2 class="info-label">Description</h2>
              <p class="info-description">{project.description}</p>
            </div>
            
            <div class="info-column side-info">
              <div class="info-group">
                <h3 class="info-label">Publications</h3>
                <ul class="info-list">
                  {project.publications.map(pub => (
                    <li><a href={pub.url}>{pub.title}</a></li>
                  ))}
                </ul>
              </div>

              <div class="info-group">
                <h3 class="info-label">Team</h3>
                <ul class="info-list">
                  {project.team.map(member => (
                    <li>
                      <span class="member-name">{member.name}</span>
                      <span class="member-role">{member.role}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="info-group">
                <h3 class="info-label">Consortium</h3>
                <ul class="info-list">
                  {project.consortium.map(entity => (
                    <li>{entity}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
          <footer class="info-footer">
            <a href={withBase('/projects/')} class="back-link">← Return to Projects</a>
          </footer>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  :root {
    --color-green-primary: #10b981;
    --color-green-dark: #064e3b;
    --color-green-light: #d1fae5;
    --color-bg-dark: #0a0a0a;
    --font-tech: 'Inter', system-ui, sans-serif;
  }

  .scrolly-container {
    background-color: var(--color-bg-dark);
    color: white;
    font-family: var(--font-tech);
  }

  /* FIXED UI */
  .fixed-ui {
    position: fixed;
    top: 2rem;
    left: 2rem;
    z-index: 100;
  }

  .brand-logos {
    display: flex;
    align-items: center;
    gap: 2rem;
    opacity: 0.9;
    mix-blend-mode: exclusion;
  }

  .logo-unipv {
    height: 60px; /* Increased from 40px */
    filter: brightness(0) invert(1);
  }

  .logo-ramslab {
    height: 45px; /* Increased from 30px */
  }

  .logo-separator {
    width: 1px;
    height: 45px; /* Increased from 30px */
    background-color: rgba(255, 255, 255, 0.4);
  }

  /* SECTION BASE */
  .section {
    position: relative;
    height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bg-media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .bg-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.4;
  }

  .bg-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent, rgba(0,0,0,0.8));
  }

  .content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    padding: 2rem;
  }

  /* HERO */
  .title-main {
    font-size: clamp(4rem, 15vw, 10rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    margin: 0;
    line-height: 0.9;
    text-transform: uppercase;
    color: var(--color-green-primary);
  }

  .subtitle {
    font-size: 1.25rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-top: 1rem;
    opacity: 0.7;
  }

  /* LOCOMOTION SECTION */
  .locomotion-bg {
    background-color: #050505;
  }

  .hero-bg-video {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    transform: translate(-50%, -50%);
    object-fit: cover;
    opacity: 0.4;
    display: block;
    z-index: 0;
  }



  .reveal-slide {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal-slide.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* CONTENT SECTIONS */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
    padding: 0 4rem;
  }

  .visual-block {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .alternate .content-grid {
    grid-template-columns: 1.2fr 0.8fr;
  }

  .section-label {
    color: var(--color-green-primary);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .text-block p {
    font-size: 1.5rem;
    line-height: 1.4;
    opacity: 0.9;
    max-width: 450px;
  }

  /* RECAP SECTION - INFORMATION BOX */
  .recap-section {
    padding: 120px 0;
    background-color: white;
    color: black;
  }

  .info-box {
    background-color: #f0fdf4; /* Light green background */
    border-radius: 4px;
    padding: 60px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 80px;
  }

  .info-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 24px;
    color: #666;
    font-weight: 700;
  }

  .info-description {
    font-size: 1.75rem;
    line-height: 1.3;
    font-weight: 400;
    color: #111;
  }

  .info-group {
    margin-bottom: 48px;
  }

  .info-group:last-child {
    margin-bottom: 0;
  }

  .info-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .info-list li {
    padding: 16px 0;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 1.1rem;
    line-height: 1.4;
  }

  .info-list li:first-child {
    border-top: none;
    padding-top: 0;
  }

  .info-list a {
    color: black;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .info-list a:hover {
    opacity: 0.6;
  }

  .member-name {
    display: block;
    font-weight: 600;
  }

  .member-role {
    font-size: 0.85rem;
    color: #666;
  }

  .info-footer {
    margin-top: 60px;
    padding-top: 32px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    text-align: left;
  }

  .back-link {
    color: #666;
    text-decoration: none;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
  }

  .back-link:hover {
    color: black;
  }

  /* ANIMATIONS */
  .parallax-bg {
    transition: transform 0.1s ease-out;
  }

  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }

  .tree-3d-container {
    position: relative;
    width: 860px;
    height: 1050px;
    margin: 0 auto;
    z-index: 1;
    cursor: grab;
  }
  
  .tree-3d-container:active {
    cursor: grabbing;
  }

  .tech-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .side-sync-video {
    aspect-ratio: 9 / 16 !important;
    width: 280px !important;
    height: auto !important;
    margin: 0 auto;
    transform: translateX(60px);
    border: 2px solid var(--color-green-primary) !important;
    box-shadow: 0 0 30px rgba(16, 185, 129, 0.2);
  }

  .video-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-green-primary);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: linear-gradient(45deg, #050505, #111);
  }

  .abstract-viz {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .viz-line {
    height: 2px;
    background: var(--color-green-primary);
    width: 100%;
    animation: pulse 4s infinite;
  }

  .delay-1 { animation-delay: 1s; }
  .delay-2 { animation-delay: 2s; }

  @keyframes pulse {
    0%, 100% { opacity: 0.2; transform: scaleX(0.8); }
    50% { opacity: 1; transform: scaleX(1); }
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .side-sync-video {
      transform: translateX(0);
      width: 240px !important;
    }
    .content-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 0 2rem;
    }
    .info-box { padding: 30px; }
    .info-grid { grid-template-columns: 1fr; gap: 40px; }
    .info-description { font-size: 1.4rem; }
    .fixed-ui { top: 1rem; left: 1rem; }
    .brand-logos { gap: 1rem; }
    .logo-unipv { height: 40px; }
    .logo-ramslab { height: 30px; }
    .tree-3d-container {
      width: 100%;
      height: 600px;
    }
  }
</style>

<script>
  // Simple scrollytelling logic
  const sections = document.querySelectorAll('.section');
  const parallaxBgs = document.querySelectorAll('.parallax-bg');

  // Reveal elements on scroll
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal, .reveal-slide').forEach(el => revealObserver.observe(el));

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    
    // Parallax effect
    parallaxBgs.forEach(bg => {
      const speed = 0.2;
      const offset = scrollY * speed;
      (bg as HTMLElement).style.transform = `translateY(${offset}px)`;
    });
  });

  // THREE.JS ANIMATION
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';
  import gsap from 'gsap';

  class TreeAnimation {
    private container: HTMLElement;
    private scene: THREE.Scene;
    private camera: THREE.PerspectiveCamera;
    private renderer: THREE.WebGLRenderer;
    private controls: OrbitControls;
    private modelGroup: THREE.Group;
    private pointsGroup: THREE.Group;
    private wireframeGroup: THREE.Group;
    private finalGroup: THREE.Group;
    private timeline: gsap.core.Timeline | null = null;
    private isAnimating = false;

    constructor(containerId: string, private modelPath: string) {
      const container = document.getElementById(containerId);
      if (!container) return;
      this.container = container;

      this.scene = new THREE.Scene();
      this.camera = new THREE.PerspectiveCamera(45, this.container.clientWidth / this.container.clientHeight, 0.1, 2000);
      this.renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
      this.modelGroup = new THREE.Group();
      this.pointsGroup = new THREE.Group();
      this.wireframeGroup = new THREE.Group();
      this.finalGroup = new THREE.Group();
      
      this.controls = new OrbitControls(this.camera, this.renderer.domElement);
      this.init();
    }

    private init() {
      this.renderer.setSize(this.container.clientWidth, this.container.clientHeight);
      this.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      this.container.appendChild(this.renderer.domElement);

      this.camera.position.set(0, -1, 10); // Start position
      this.scene.add(this.modelGroup);
      this.modelGroup.add(this.pointsGroup, this.wireframeGroup, this.finalGroup);

      // Controls Setup
      this.controls.enableDamping = true;
      this.controls.dampingFactor = 0.05;
      this.controls.enablePan = false;
      this.controls.minPolarAngle = Math.PI / 2.2; 
      this.controls.maxPolarAngle = Math.PI / 1.8;
      this.controls.enabled = false; // Disable until timeline finishes

      // Lights
      const ambientLight = new THREE.AmbientLight(0xffffff, 1.0); // Brighter ambient
      this.scene.add(ambientLight);
      
      const pointLight = new THREE.PointLight(0xffffff, 2.0); // Brighter light for textures
      pointLight.position.set(10, 20, 10);
      this.scene.add(pointLight);

      this.loadModel();
      this.setupEventListeners();
      this.animate();
    }

    private loadModel() {
      const loader = new GLTFLoader();

      loader.load(this.modelPath, (gltf) => {
        const model = gltf.scene;
        
        const box = new THREE.Box3().setFromObject(model);
        const center = box.getCenter(new THREE.Vector3());
        const size = box.getSize(new THREE.Vector3());
        
        model.traverse((child) => {
          if ((child as THREE.Mesh).isMesh) {
            const mesh = child as THREE.Mesh;
            mesh.updateMatrixWorld();
            const geometry = mesh.geometry.clone();
            geometry.applyMatrix4(mesh.matrixWorld);

            // 1. Points
            const pointsMaterial = new THREE.PointsMaterial({
              color: 0x10b981,
              size: 0.015,
              transparent: true,
              opacity: 0
            });
            const points = new THREE.Points(geometry, pointsMaterial);
            this.pointsGroup.add(points);

            // 2. Wireframe
            const wireframeMaterial = new THREE.MeshBasicMaterial({
              color: 0x10b981,
              wireframe: true,
              transparent: true,
              opacity: 0
            });
            const wireframe = new THREE.Mesh(geometry, wireframeMaterial);
            this.wireframeGroup.add(wireframe);

            // 3. Final Textured Mesh
            const final = mesh.clone();
            final.geometry = geometry;
            final.position.set(0, 0, 0);
            final.rotation.set(0, 0, 0);
            final.scale.set(1, 1, 1);
            
            // Ensure material is ready for animation
            if (Array.isArray(final.material)) {
              final.material = final.material.map(m => {
                const newM = m.clone();
                newM.transparent = true;
                newM.opacity = 0;
                return newM;
              });
            } else {
              final.material = final.material.clone();
              final.material.transparent = true;
              final.material.opacity = 0;
            }
            this.finalGroup.add(final);
          }
        });

        this.modelGroup.position.sub(center);
        const maxDim = Math.max(size.x, size.y, size.z);
        const scaleFactor = 15 / maxDim; 
        this.modelGroup.scale.set(scaleFactor, scaleFactor, scaleFactor);
        this.modelGroup.position.y -= (size.y * scaleFactor) * 0.4;

        this.setupTimeline();
      });
    }

    private setupTimeline() {
      this.timeline = gsap.timeline({ 
        paused: true,
        onComplete: () => { this.controls.enabled = true; } 
      });

      const pMats: THREE.Material[] = [];
      this.pointsGroup.traverse(c => { if((c as THREE.Points).isPoints) pMats.push((c as THREE.Points).material as THREE.Material); });
      const wMats: THREE.Material[] = [];
      this.wireframeGroup.traverse(c => { if((c as THREE.Mesh).isMesh) wMats.push((c as THREE.Mesh).material as THREE.Material); });
      const fMats: THREE.Material[] = [];
      this.finalGroup.traverse(c => { if((c as THREE.Mesh).isMesh) {
        if(Array.isArray((c as THREE.Mesh).material)) fMats.push(...((c as THREE.Mesh).material as THREE.Material[]));
        else fMats.push((c as THREE.Mesh).material as THREE.Material);
      }});

      // Consolidated smooth zoom and reconstruction
      this.timeline.to(this.camera.position, { 
        z: 24, 
        duration: 8, 
        ease: "power1.inOut" 
      }, 0);

      this.timeline.to(pMats, { opacity: 1, duration: 2.5, ease: "none", stagger: 0.1 }, 0);
      this.timeline.to(wMats, { opacity: 0.3, duration: 2.5, ease: "none", stagger: 0.1 }, 1.5);
      this.timeline.to(fMats, { opacity: 1, duration: 4, ease: "power2.inOut", stagger: 0.15 }, 3.5);
      this.timeline.to([...pMats, ...wMats], { opacity: 0.1, duration: 3 }, 5);
    }

    private setupEventListeners() {
      window.addEventListener('resize', () => {
        this.camera.aspect = this.container.clientWidth / this.container.clientHeight;
        this.camera.updateProjectionMatrix();
        this.renderer.setSize(this.container.clientWidth, this.container.clientHeight);
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            this.isAnimating = true;
            this.timeline?.play();
          } else {
            this.isAnimating = false;
          }
        });
      }, { threshold: 0.2 });

      observer.observe(this.container);
    }

    private animate() {
      requestAnimationFrame(() => this.animate());

      if (!this.isAnimating) return;

      this.controls.update();

      // Only auto-rotate if not interacting
      if (!this.controls.enabled || (!this.controls.activeLook && !document.querySelector('.tree-3d-container:active'))) {
        this.modelGroup.rotation.y += 0.0008;
      }

      this.renderer.render(this.scene, this.camera);
    }
  }

  // Initialize
  const container = document.getElementById('tree-canvas-container');
  if (container) {
    const modelPath = container.getAttribute('data-model') || '/models/tree.glb';
    new TreeAnimation('tree-canvas-container', modelPath);
  }
</script>
