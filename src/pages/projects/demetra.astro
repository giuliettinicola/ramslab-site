---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../lib/assets';

const project = {
  title: "DEMETRA",
  subtitle: "Pruning Virtual Training Simulator",
  vision: "Redefining agricultural precision through immersive virtual environments and robotic simulation.",
  description: "DEMETRA is an advanced research platform focused on the digitization of pruning techniques. By combining high-fidelity physics simulations with immersive virtual reality, the project provides a safe and optimized environment for training agricultural workers and testing robotic pruning algorithms.",
  publications: [
    { title: "Virtual Reality for Agricultural Training: The DEMETRA Platform", url: "#" },
    { title: "Real-time Simulation of Pruning Dynamics in Virtual Environments", url: "#" },
    { title: "Robotic Pruning: A Survey of Simulation-to-Real Transfer", url: "#" }
  ],
  team: [
    { name: "Nicola Giulietti", role: "Principal Investigator" },
    { name: "RAMS Lab Team", role: "Researchers & Developers" },
    { name: "University of Pavia", role: "Institutional Partner" }
  ]
};
---

<BaseLayout title={`${project.title} — Immersive Experience`}>
  <div class="scrolly-container">
    <!-- FIXED LOGO OVERLAY -->
    <div class="fixed-ui">
      <div class="brand-logos">
        <img src={withBase('/images/brand/unipv-main-logo-white.png')} alt="UNIPV" class="logo-unipv" />
        <div class="logo-separator"></div>
        <img src={withBase('/images/brand/ramslab-logo-white.svg')} alt="RAMS Lab" class="logo-ramslab" />
      </div>
    </div>

    <!-- SECTION 1: HERO -->
    <section class="section hero-section">
      <div class="bg-media">
        <img src={withBase('/images/projects/demetra-hero-bg.png')} alt="Hero Background" class="parallax-bg" />
        <div class="bg-overlay"></div>
      </div>
      <div class="content">
        <h1 class="title-main">{project.title}</h1>
        <p class="subtitle">{project.subtitle}</p>
      </div>
    </section>

    <!-- SECTION 2: VISION -->
    <section class="section vision-section">
      <div class="bg-media vision-bg">
        <img src={withBase('/images/projects/demetra-vision-bg.png')} alt="Vision Background" />
      </div>
      <div class="content">
        <blockquote class="vision-quote">
          {project.vision}
        </blockquote>
      </div>
    </section>

    <!-- SECTION 3: MODULAR CONTENT - THE SYSTEM -->
    <section class="section content-section nature-bg">
      <div class="bg-media">
        <img src={withBase('/images/projects/demetra-nature-texture.png')} alt="Nature Texture" class="parallax-bg" />
      </div>
      <div class="content-grid container">
        <div class="text-block reveal">
          <h2 class="section-label">Digital Twin</h2>
          <p>The system creates a perfect digital replica of agricultural environments, allowing for the precise modeling of tree morphology and pruning responses.</p>
        </div>
        <div class="visual-block reveal">
          <div class="tech-video-container">
            <video 
              src={withBase('/videos/projects/demetra-digital-twin.mp4')} 
              autoplay 
              loop 
              muted 
              playsinline 
              class="tech-video"
            >
              <div class="video-placeholder">Digital Twin Animation</div>
            </video>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 4: MODULAR CONTENT - TRAINING -->
    <section class="section content-section alternate">
      <div class="content-grid container">
        <div class="visual-block reveal">
          <div class="abstract-viz">
            <div class="viz-line"></div>
            <div class="viz-line delay-1"></div>
            <div class="viz-line delay-2"></div>
          </div>
        </div>
        <div class="text-block reveal">
          <h2 class="section-label">Skill Acquisition</h2>
          <p>Real-time haptic feedback and visual analytics guide the user through complex pruning decisions, accelerating the learning curve for sustainable practices.</p>
        </div>
      </div>
    </section>

    <!-- SECTION 5: RECAP -->
    <section class="section recap-section">
      <div class="container recap-grid">
        <div class="recap-info">
          <h2 class="recap-title">Description</h2>
          <p>{project.description}</p>
        </div>
        
        <div class="recap-lists">
          <div class="recap-group">
            <h3 class="recap-subtitle">Publications</h3>
            <ul class="clean-list">
              {project.publications.map(pub => (
                <li><a href={pub.url}>{pub.title}</a></li>
              ))}
            </ul>
          </div>

          <div class="recap-group">
            <h3 class="recap-subtitle">Team</h3>
            <ul class="clean-list">
              {project.team.map(member => (
                <li>
                  <span class="member-name">{member.name}</span>
                  <span class="member-role">{member.role}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
      <footer class="recap-footer">
        <a href={withBase('/projects/')} class="back-link">← Return to Projects</a>
      </footer>
    </section>
  </div>
</BaseLayout>

<style>
  :root {
    --color-green-primary: #10b981;
    --color-green-dark: #064e3b;
    --color-green-light: #d1fae5;
    --color-bg-dark: #0a0a0a;
    --font-tech: 'Inter', system-ui, sans-serif;
  }

  .scrolly-container {
    background-color: var(--color-bg-dark);
    color: white;
    font-family: var(--font-tech);
    overflow-x: hidden;
  }

  /* FIXED UI */
  .fixed-ui {
    position: fixed;
    top: 2rem;
    left: 2rem;
    z-index: 100;
  }

  .brand-logos {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    opacity: 0.8;
    mix-blend-mode: exclusion;
  }

  .logo-unipv {
    height: 40px;
    filter: brightness(0) invert(1);
  }

  .logo-ramslab {
    height: 30px;
  }

  .logo-separator {
    width: 1px;
    height: 30px;
    background-color: rgba(255, 255, 255, 0.4);
  }

  /* SECTION BASE */
  .section {
    position: relative;
    height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bg-media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .bg-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.4;
  }

  .bg-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent, rgba(0,0,0,0.8));
  }

  .content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    padding: 2rem;
  }

  /* HERO */
  .title-main {
    font-size: clamp(4rem, 15vw, 10rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    margin: 0;
    line-height: 0.9;
    text-transform: uppercase;
    color: var(--color-green-primary);
  }

  .subtitle {
    font-size: 1.25rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-top: 1rem;
    opacity: 0.7;
  }

  /* VISION */
  .vision-section {
    background-color: #050505;
  }

  .vision-quote {
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 300;
    line-height: 1.1;
    max-width: 1000px;
    color: white;
    text-align: left;
    margin: 0;
  }

  /* CONTENT SECTIONS */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    width: 100%;
    padding: 0 4rem;
  }

  .alternate .content-grid {
    grid-template-columns: 1.2fr 0.8fr;
  }

  .section-label {
    color: var(--color-green-primary);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  .text-block p {
    font-size: 1.5rem;
    line-height: 1.4;
    opacity: 0.9;
    max-width: 450px;
  }

  /* RECAP */
  .recap-section {
    height: auto;
    min-height: 100vh;
    padding: 10rem 0 5rem;
    align-items: flex-start;
    background-color: white;
    color: black;
  }

  .recap-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .recap-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 2rem;
    color: #666;
  }

  .recap-info p {
    font-size: 2rem;
    line-height: 1.2;
    font-weight: 400;
  }

  .recap-subtitle {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
    color: #666;
  }

  .clean-list {
    list-style: none;
    padding: 0;
    margin: 0 0 4rem 0;
  }

  .clean-list li {
    padding: 1.5rem 0;
    border-bottom: 1px solid #eee;
  }

  .clean-list a {
    color: black;
    text-decoration: none;
    font-size: 1.25rem;
    display: block;
    transition: opacity 0.2s;
  }

  .clean-list a:hover {
    opacity: 0.5;
  }

  .member-name {
    display: block;
    font-size: 1.25rem;
    font-weight: 500;
  }

  .member-role {
    font-size: 0.875rem;
    color: #666;
  }

  .recap-footer {
    padding-top: 5rem;
    text-align: center;
    width: 100%;
  }

  .back-link {
    color: #666;
    text-decoration: none;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* ANIMATIONS */
  .parallax-bg {
    transition: transform 0.1s ease-out;
  }

  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }

  .tech-video-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
    border: 1px solid var(--color-green-dark);
    overflow: hidden;
  }

  .tech-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-green-primary);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: linear-gradient(45deg, #050505, #111);
  }

  .tech-diagram {
    color: var(--color-green-primary);
    width: 300px;
    height: 300px;
    margin: 0 auto;
  }

  .abstract-viz {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .viz-line {
    height: 2px;
    background: var(--color-green-primary);
    width: 100%;
    animation: pulse 4s infinite;
  }

  .delay-1 { animation-delay: 1s; }
  .delay-2 { animation-delay: 2s; }

  @keyframes pulse {
    0%, 100% { opacity: 0.2; transform: scaleX(0.8); }
    50% { opacity: 1; transform: scaleX(1); }
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .content-grid, .recap-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 0 2rem;
    }
    .recap-info p { font-size: 1.5rem; }
    .fixed-ui { top: 1rem; left: 1rem; }
    .brand-logos { gap: 1rem; }
    .logo-unipv { height: 30px; }
    .logo-ramslab { height: 20px; }
  }
</style>

<script>
  // Simple scrollytelling logic
  const sections = document.querySelectorAll('.section');
  const parallaxBgs = document.querySelectorAll('.parallax-bg');

  // Reveal elements on scroll
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    
    // Parallax effect
    parallaxBgs.forEach(bg => {
      const speed = 0.2;
      const offset = scrollY * speed;
      (bg as HTMLElement).style.transform = `translateY(${offset}px)`;
    });
  });
</script>
