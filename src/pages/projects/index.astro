---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/assets';
import { entrySlug } from '../../lib/entries';

const projects = (await getCollection('projects')).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return Number(b.data.featured) - Number(a.data.featured);
  return (b.data.year ?? 0) - (a.data.year ?? 0);
});
---

<BaseLayout title="Projects — RAMSLAB">
  <Header />
  <main class="projects-page-main">
    <section class="projects-header-section">
      <div class="projects-header-container">
        <div class="projects-header-content">
          <h1 class="projects-title-big">Projects</h1>
          <span class="projects-text-little-text" style="width: 150px;">
            {projects.length} project entries · ordered by featured status and year
          </span>
        </div>
      </div>
    </section>

    <section class="projects-list-section">
      <div class="projects-list-container">
        {projects.map((project, index) => (
          <article class={`project-item-row ${index === 0 ? 'first-row' : ''}`}>
            <div class="project-meta-left">
              <span class="projects-text-little-text">{project.data.year ? String(project.data.year) : 'Undated'}</span>
              <span class="projects-text-little-text">{project.data.status ?? 'Project record'}</span>
            </div>
            <div class="project-content-middle">
              <h2 class="projects-text-link-bold-plus project-title-link">
                {(() => {
                  const href = entrySlug(project.id) === 'demetra-nodes' ? withBase('/projects/demetra/') : 
                    entrySlug(project.id) === 'carbon-fiber' ? withBase('/projects/composite-manufacturing/') : 
                    undefined;
                  return href ? <a href={href}>{project.data.title}</a> : project.data.title;
                })()}
              </h2>
              {project.data.excerpt && <p class="projects-text-link-header">{project.data.excerpt}</p>}
            </div>
            <div class="project-meta-right">
              {project.data.tags && project.data.tags.length > 0 && (
                <span class="projects-text-little-text">
                  {project.data.tags.slice(0, 2).join(' · ')}
                </span>
              )}
              {project.data.people && project.data.people.length > 0 && (
                <span class="projects-text-little-text">
                  {project.data.people.length} related people
                </span>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
